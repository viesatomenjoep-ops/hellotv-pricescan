# ---------------------------------------------------------------------------
# hellotv-pricescan — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit .env.local
# ---------------------------------------------------------------------------

# Supabase (Postgres, Auth, RLS)
# NEXT_PUBLIC_* are exposed to the browser; the service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vendit API
VENDIT_API_BASE_URL=
VENDIT_API_KEY=
VENDIT_API_SECRET=

# Cron / scheduled jobs (shared secret to protect cron endpoints)
CRON_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
